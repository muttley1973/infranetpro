# InfraNet Pro — variabili d'ambiente per Docker Compose
# Copia in .env:   cp .env.example .env
# (.env è già git-ignored: non finisce nel repo)

# Secret di firma delle sessioni — DEVE essere fisso e segreto.
# Se cambia (o non è impostato) tutti gli utenti vengono disconnessi.
# Genera un valore casuale lungo, p.es.:
#   openssl rand -base64 48
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=CAMBIA-QUESTO-con-un-valore-casuale-lungo

# Porta pubblicata sul loopback dell'host (opzionale, default 8421)
# PORT=8421

# Indirizzo di pubblicazione (opzionale, default 127.0.0.1 = solo loopback dell'host).
# Per raggiungere l'app dalla LAN imposta:  BIND_ADDR=0.0.0.0
# BIND_ADDR=127.0.0.1

# Modalità di rete del container: bridge (default) o host.
# host = il container vede la tabella ARP reale → MAC + vendor nella discovery (come bare-metal).
# In host mode 'ports'/BIND_ADDR sono ignorati: il bind segue HOST (default 0.0.0.0).
# NETWORK_MODE=host
