{
  "//": "Type-check dei moduli PURI (UMD-lite) via JSDoc + checkJs (npm run typecheck). Nessun emit: i .js restano identici a runtime. Il glue app-*.js (scope globale) resta fuori per scelta.",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020", "DOM"],
    "types": [],
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "lib/types.d.ts",
    "lib/audit-log.js",
    "lib/cable-labels.js",
    "lib/cable-validate.js",
    "lib/cabling.js",
    "lib/cidr.js",
    "lib/correlate.js",
    "lib/drift-adopt.js",
    "lib/drift-report.js",
    "lib/drift-snapshot.js",
    "lib/frontpanel.js",
    "lib/ha-pair.js",
    "lib/handoff.js",
    "lib/i18n.js",
    "lib/ipam.js",
    "lib/l3-gateway.js",
    "lib/linkstate.js",
    "lib/mac-class.js",
    "lib/netnames.js",
    "lib/panel-skin.js",
    "lib/power-mib.js",
    "lib/radio.js",
    "lib/spare-ports.js",
    "lib/stack.js",
    "lib/topo-lines.js",
    "lib/vlan-trunk.js",
    "lib/wave-path.js",
    "lib/wifi-spec.js",
    "lib/wifi-vlan-check.js"
  ]
}
